# API base URL the client calls. Falls back to http://localhost:5000/api/v1
# in development if unset — MUST be set to the real production API origin
# when building for deployment (Vite inlines this at build time, not
# runtime, so it has to be correct in the environment that runs `npm run build`).
# Production value:
VITE_API_URL=https://tartelah.com/api/v1

# Optional: shows the dev-only instant-role-login button on the login page.
# Leave unset in production.
VITE_ENABLE_DEMO_LOGIN=false
