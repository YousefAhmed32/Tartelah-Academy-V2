# Application
NODE_ENV=development
PORT=5000
# The frontend origin — drives CORS, password-reset/verification email links,
# and the Socket.io CORS origin. CLIENT_URL is preferred; FRONTEND_URL is
# still read as a fallback for any already-configured deployment.
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/tartelah

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=ترتيلة أونلاين <noreply@tartelah.com>

# File Uploads
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Rate Limiting
# Requests are counted per-user (logged-in) or per-IP (public visitors) within
# each window. Student/teacher get the same high ceiling since both are
# regular authenticated academy usage; admin gets extra headroom for
# dashboard/report-heavy screens; public (unauthenticated) stays strict.
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_PUBLIC=300
RATE_LIMIT_STUDENT=1000
RATE_LIMIT_TEACHER=1000
RATE_LIMIT_ADMIN=3000
RATE_LIMIT_LOGIN=100

# AI Assistant (OpenAI) — server-side only, never exposed to the client.
# Without OPENAI_API_KEY set, both AI endpoints run in deterministic
# rule-based/real-data fallback mode instead of failing.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
